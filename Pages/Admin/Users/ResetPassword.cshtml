@page "{id}"
@model BenueCommunityMapping.Pages.Admin.Users.ResetPasswordModel
@{ ViewData["Title"] = "Reset Password"; }

<div class="page-hero mt-3">
  <div class="hero-icon"><i class="bi bi-key"></i></div>
  <div><h1>Reset Password</h1><p>Set a new password for @Model.TargetName</p></div>
</div>

<div class="row"><div class="col-lg-5">
  <div class="content-card">
    <div class="content-card-header"><i class="bi bi-lock-fill"></i><h5>New Password</h5></div>
    <div class="content-card-body">
      <form method="post">
        <input type="hidden" asp-for="Input.UserId" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>
        <div class="mb-3">
          <label asp-for="Input.NewPassword" class="form-label">New Password <span class="required-star">*</span></label>
          <input asp-for="Input.NewPassword" class="form-control" type="password" placeholder="Min 8 chars…" />
          <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
        </div>
        <div class="mb-4">
          <label asp-for="Input.Confirm" class="form-label">Confirm Password <span class="required-star">*</span></label>
          <input asp-for="Input.Confirm" class="form-control" type="password" placeholder="Repeat password" />
          <span asp-validation-for="Input.Confirm" class="text-danger small"></span>
        </div>
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-bsbs-primary"><i class="bi bi-key me-1"></i>Reset Password</button>
          <a asp-page="Agents" class="btn btn-bsbs-outline">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }

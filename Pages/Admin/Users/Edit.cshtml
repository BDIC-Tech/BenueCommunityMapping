@page "{id}"
@model BenueCommunityMapping.Pages.Admin.Users.EditModel
@{
    ViewData["Title"] = "Edit User";
    bool isCoordinator = Model.Input.Role == "Coordinator";
}

<div class="page-hero mt-3">
  <div class="hero-icon"><i class="bi bi-person-gear"></i></div>
  <div>
    <h1>Edit User</h1>
    <p>Update account details for @Model.Input.FirstName @Model.Input.LastName
      <span class="badge bg-secondary ms-1">@Model.Input.Role</span>
    </p>
  </div>
</div>

<div class="row">
  <div class="col-lg-7">
    <div class="content-card">
      <div class="content-card-header">
        <i class="bi bi-person-fill"></i>
        <h5>User Details</h5>
      </div>
      <div class="content-card-body">
        <form method="post">
          <input type="hidden" asp-for="Input.Id" />
          <input type="hidden" asp-for="Input.Role" />
          <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>

          <div class="row g-3">
            <div class="col-md-6">
              <label asp-for="Input.FirstName" class="form-label">First Name <span class="required-star">*</span></label>
              <input asp-for="Input.FirstName" class="form-control" />
              <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="Input.LastName" class="form-label">Last Name <span class="required-star">*</span></label>
              <input asp-for="Input.LastName" class="form-control" />
              <span asp-validation-for="Input.LastName" class="text-danger small"></span>
            </div>
            <div class="col-12">
              <label class="form-label text-muted">Email (read-only)</label>
              <input value="@Model.Email" class="form-control" disabled />
            </div>

            <!-- LGA dropdown -->
            <div class="col-md-6">
              <label asp-for="Input.LGA" class="form-label">Local Government Area</label>
              <select asp-for="Input.LGA" class="form-select" id="lgaSelect">
                <option value="">– Select LGA –</option>
                @foreach (var lga in Model.LGAs)
                {
                  <option value="@lga.Name">@lga.Name</option>
                }
              </select>
            </div>

            <!-- Ward dropdown (hidden for Coordinators) -->
            <div class="col-md-6" id="wardDiv" style="display:@(isCoordinator ? "none" : "block")">
              <label asp-for="Input.Ward" class="form-label">Assigned Ward</label>
              <select asp-for="Input.Ward" class="form-select" id="wardSelect">
                <option value="">– Select Ward –</option>
                @foreach (var w in Model.Wards)
                {
                  <option value="@w.Name">@w.Name</option>
                }
              </select>
            </div>

            <!-- Coordinator assignment – only for Agents -->
            @if (Model.Input.Role == AppRoles.Agent)
            {
              <div class="col-12">
                <label asp-for="Input.CoordinatorId" class="form-label">Coordinator</label>
                <select asp-for="Input.CoordinatorId" class="form-select"
                        asp-items="@(new SelectList(Model.Coordinators, "Id", "FullName"))">
                  <option value="">— No Coordinator —</option>
                </select>
              </div>
            }
          </div>

          <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-bsbs-primary">
              <i class="bi bi-floppy me-1"></i>Save Changes
            </button>
            <a asp-page="@(Model.Input.Role == AppRoles.Coordinator ? "Coordinators" : "Agents")"
               class="btn btn-bsbs-outline">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

@section Scripts {
  <script>
    // ── LGA → Ward cascading dropdown ──
    const lgaMap = { @Html.Raw(string.Join(", ", Model.LGAs.Select(l => $"\"{l.Name}\": {l.Id}"))) };
    const isCoordinator = @(isCoordinator ? "true" : "false");

    document.getElementById('lgaSelect').addEventListener('change', async function () {
      if (isCoordinator) return; // Coordinators don't need wards

      const wardSel = document.getElementById('wardSelect');
      wardSel.innerHTML = '<option value="">– Select Ward –</option>';
      wardSel.disabled = true;

      const lgaId = lgaMap[this.value];
      if (!lgaId) return;

      try {
        const res = await fetch(`/api/geo/wards?lgaId=${lgaId}`);
        if (!res.ok) return;
        const wards = await res.json();
        wards.forEach(w => {
          const opt = new Option(w.name, w.name);
          wardSel.appendChild(opt);
        });
        wardSel.disabled = false;
      } catch { }
    });

    // On page load: if LGA already has a value, load wards and pre-select
    (async function () {
      if (isCoordinator) return;

      const lgaSel = document.getElementById('lgaSelect');
      const wardVal = '@(Model.Input.Ward ?? "")';
      if (lgaSel.value) {
        const lgaId = lgaMap[lgaSel.value];
        if (!lgaId) return;
        try {
          const res = await fetch(`/api/geo/wards?lgaId=${lgaId}`);
          if (!res.ok) return;
          const wards = await res.json();
          const wardSel = document.getElementById('wardSelect');
          wardSel.innerHTML = '<option value="">– Select Ward –</option>';
          wards.forEach(w => {
            const opt = new Option(w.name, w.name);
            if (w.name === wardVal) opt.selected = true;
            wardSel.appendChild(opt);
          });
          wardSel.disabled = false;
        } catch { }
      }
    })();
  </script>
  <partial name="_ValidationScriptsPartial" />
}

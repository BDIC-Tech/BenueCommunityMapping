@page
@model BenueCommunityMapping.Pages.Admin.Geography.IndexModel
@{
    ViewData["Title"] = "Geographic Hierarchy";
}

<div class="page-hero mt-3">
  <div class="hero-icon"><i class="bi bi-diagram-3-fill"></i></div>
  <div>
    <h1>Geographic Hierarchy</h1>
    <p>Manage the LGA → Ward → Kindred → Community reference data used for all submissions</p>
  </div>
</div>

<!-- STATS ROW -->
<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="stat-card">
      <div class="stat-icon green"><i class="bi bi-building"></i></div>
      <div><div class="stat-value">@Model.LGACount</div><div class="stat-label">LGAs</div></div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card">
      <div class="stat-icon blue"><i class="bi bi-grid-3x3-gap"></i></div>
      <div><div class="stat-value">@Model.WardCount</div><div class="stat-label">Wards</div></div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card">
      <div class="stat-icon gold"><i class="bi bi-people"></i></div>
      <div><div class="stat-value">@Model.KindredCount</div><div class="stat-label">Kindreds</div></div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card">
      <div class="stat-icon purple"><i class="bi bi-geo-alt-fill"></i></div>
      <div><div class="stat-value">@Model.CommunityCount</div><div class="stat-label">Communities</div></div>
    </div>
  </div>
</div>

<!-- TABS -->
<ul class="nav nav-tabs mb-0" id="geoTabs">
  <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabLGA">
    <i class="bi bi-building me-1"></i>LGAs
  </button></li>
  <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabWard">
    <i class="bi bi-grid-3x3-gap me-1"></i>Wards
  </button></li>
  <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabKindred">
    <i class="bi bi-people me-1"></i>Kindreds
  </button></li>
  <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabCommunity">
    <i class="bi bi-geo-alt-fill me-1"></i>Communities
  </button></li>
</ul>

<div class="tab-content">

  <!-- ── LGA TAB ── -->
  <div class="tab-pane fade show active table-card rounded-top-0" id="tabLGA">
    <div class="table-card-header">
      <h5 class="ms-1">Local Government Areas</h5>
      <button class="btn btn-bsbs-gold btn-sm ms-auto" data-bs-toggle="modal" data-bs-target="#modalLGA">
        <i class="bi bi-plus me-1"></i>Add LGA
      </button>
    </div>
    <div class="table-responsive">
      <table class="bsbs-table">
        <thead><tr><th>#</th><th>Name</th><th>Code</th><th>Wards</th><th>Status</th><th></th></tr></thead>
        <tbody>
          @foreach (var lga in Model.LGAs)
          {
            <tr>
              <td class="text-muted">@lga.Id</td>
              <td><strong>@lga.Name</strong></td>
              <td><code>@lga.Code</code></td>
              <td>@(Model.WardCounts.GetValueOrDefault(lga.Id, 0))</td>
              <td><span class="badge @(lga.IsActive ? "bg-success" : "bg-secondary")">@(lga.IsActive ? "Active" : "Inactive")</span></td>
              <td>
                <div class="d-flex gap-1">
                  <button class="btn btn-sm btn-bsbs-outline" data-bs-toggle="modal" data-bs-target="#modalEditLGA-@lga.Id" title="Edit">
                    <i class="bi bi-pencil"></i>
                  </button>
                  <form method="post" asp-page-handler="ToggleLGA" asp-route-id="@lga.Id">
                    <button class="btn btn-sm @(lga.IsActive ? "btn-outline-warning" : "btn-outline-success")" title="@(lga.IsActive ? "Deactivate" : "Activate")">
                      <i class="bi @(lga.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                    </button>
                  </form>
                  <form method="post" asp-page-handler="DeleteLGA" asp-route-id="@lga.Id" onsubmit="return confirm('Delete this LGA?')">
                    <button class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash3"></i></button>
                  </form>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>

  <!-- ── WARD TAB ── -->
  <div class="tab-pane fade table-card rounded-top-0" id="tabWard">
    <div class="table-card-header">
      <h5 class="ms-1">Wards</h5>
      <button class="btn btn-bsbs-gold btn-sm ms-auto" data-bs-toggle="modal" data-bs-target="#modalWard">
        <i class="bi bi-plus me-1"></i>Add Ward
      </button>
    </div>
    <div class="table-responsive">
      <table class="bsbs-table">
        <thead><tr><th>#</th><th>Ward Name</th><th>Code</th><th>LGA</th><th>Kindreds</th><th>Status</th><th></th></tr></thead>
        <tbody>
          @foreach (var w in Model.Wards)
          {
            <tr>
              <td class="text-muted">@w.Id</td>
              <td><strong>@w.Name</strong></td>
              <td><code>@w.Code</code></td>
              <td class="text-muted">@w.LocalGovernmentArea?.Name</td>
              <td>@(Model.KindredCounts.GetValueOrDefault(w.Id, 0))</td>
              <td><span class="badge @(w.IsActive ? "bg-success" : "bg-secondary")">@(w.IsActive ? "Active" : "Inactive")</span></td>
              <td>
                <div class="d-flex gap-1">
                  <button class="btn btn-sm btn-bsbs-outline" data-bs-toggle="modal" data-bs-target="#modalEditWard-@w.Id" title="Edit">
                    <i class="bi bi-pencil"></i>
                  </button>
                  <form method="post" asp-page-handler="ToggleWard" asp-route-id="@w.Id">
                    <button class="btn btn-sm @(w.IsActive ? "btn-outline-warning" : "btn-outline-success")" title="@(w.IsActive ? "Deactivate" : "Activate")">
                      <i class="bi @(w.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                    </button>
                  </form>
                  <form method="post" asp-page-handler="DeleteWard" asp-route-id="@w.Id" onsubmit="return confirm('Delete this Ward?')">
                    <button class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash3"></i></button>
                  </form>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>

  <!-- ── KINDRED TAB ── -->
  <div class="tab-pane fade table-card rounded-top-0" id="tabKindred">
    <div class="table-card-header">
      <h5 class="ms-1">Kindreds</h5>
      <button class="btn btn-bsbs-gold btn-sm ms-auto" data-bs-toggle="modal" data-bs-target="#modalKindred">
        <i class="bi bi-plus me-1"></i>Add Kindred
      </button>
    </div>
    <div class="table-responsive">
      <table class="bsbs-table">
        <thead><tr><th>#</th><th>Kindred</th><th>Code</th><th>Ward</th><th>LGA</th><th>Communities</th><th>Status</th><th></th></tr></thead>
        <tbody>
          @foreach (var k in Model.Kindreds)
          {
            <tr>
              <td class="text-muted">@k.Id</td>
              <td><strong>@k.Name</strong></td>
              <td><code>@k.Code</code></td>
              <td class="text-muted">@k.Ward?.Name</td>
              <td class="text-muted">@k.Ward?.LocalGovernmentArea?.Name</td>
              <td>@(Model.CommunityCounts.GetValueOrDefault(k.Id, 0))</td>
              <td><span class="badge @(k.IsActive ? "bg-success" : "bg-secondary")">@(k.IsActive ? "Active" : "Inactive")</span></td>
              <td>
                <div class="d-flex gap-1">
                  <button class="btn btn-sm btn-bsbs-outline" data-bs-toggle="modal" data-bs-target="#modalEditKindred-@k.Id" title="Edit">
                    <i class="bi bi-pencil"></i>
                  </button>
                  <form method="post" asp-page-handler="ToggleKindred" asp-route-id="@k.Id">
                    <button class="btn btn-sm @(k.IsActive ? "btn-outline-warning" : "btn-outline-success")" title="@(k.IsActive ? "Deactivate" : "Activate")">
                      <i class="bi @(k.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                    </button>
                  </form>
                  <form method="post" asp-page-handler="DeleteKindred" asp-route-id="@k.Id" onsubmit="return confirm('Delete this Kindred?')">
                    <button class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash3"></i></button>
                  </form>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>

  <!-- ── COMMUNITY TAB ── -->
  <div class="tab-pane fade table-card rounded-top-0" id="tabCommunity">
    <div class="table-card-header">
      <h5 class="ms-1">Communities</h5>
      <button class="btn btn-bsbs-gold btn-sm ms-auto" data-bs-toggle="modal" data-bs-target="#modalCommunity">
        <i class="bi bi-plus me-1"></i>Add Community
      </button>
    </div>
    <div class="table-responsive">
      <table class="bsbs-table">
        <thead><tr><th>#</th><th>Community</th><th>Code</th><th>Kindred</th><th>Ward</th><th>LGA</th><th>Pop.</th><th>Submissions</th><th>Status</th><th></th></tr></thead>
        <tbody>
          @foreach (var c in Model.Communities)
          {
            <tr>
              <td class="text-muted">@c.Id</td>
              <td><strong>@c.Name</strong></td>
              <td><code>@c.Code</code></td>
              <td class="text-muted">@c.Kindred?.Name</td>
              <td class="text-muted">@c.Kindred?.Ward?.Name</td>
              <td class="text-muted">@c.Kindred?.Ward?.LocalGovernmentArea?.Name</td>
              <td>@(c.EstimatedPopulation?.ToString("N0") ?? "–")</td>
              <td><span class="badge bg-secondary rounded-pill">@(Model.SubmissionCounts.GetValueOrDefault(c.Id, 0))</span></td>
              <td><span class="badge @(c.IsActive ? "bg-success" : "bg-secondary")">@(c.IsActive ? "Active" : "Inactive")</span></td>
              <td>
                <div class="d-flex gap-1">
                  <button class="btn btn-sm btn-bsbs-outline" data-bs-toggle="modal" data-bs-target="#modalEditCommunity-@c.Id" title="Edit">
                    <i class="bi bi-pencil"></i>
                  </button>
                  <form method="post" asp-page-handler="ToggleCommunity" asp-route-id="@c.Id">
                    <button class="btn btn-sm @(c.IsActive ? "btn-outline-warning" : "btn-outline-success")" title="@(c.IsActive ? "Deactivate" : "Activate")">
                      <i class="bi @(c.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                    </button>
                  </form>
                  <form method="post" asp-page-handler="DeleteCommunity" asp-route-id="@c.Id" onsubmit="return confirm('Delete this Community?')">
                    <button class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash3"></i></button>
                  </form>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ── MODALS ── -->
<div class="modal fade" id="modalLGA" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-bsbs-accent"><h5 class="modal-title">Add Local Government Area</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="post" asp-page-handler="AddLGA">
      <div class="modal-body">
        <div class="mb-3"><label class="form-label">LGA Name <span class="required-star">*</span></label>
          <input name="lgaName" class="form-control" required placeholder="e.g. Makurdi" /></div>
        <div class="mb-3"><label class="form-label">LGA Code <span class="required-star">*</span></label>
          <input name="lgaCode" class="form-control" required placeholder="e.g. BN-MKD" /></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-bsbs-primary">Add LGA</button>
      </div>
    </form>
  </div></div>
</div>

<div class="modal fade" id="modalWard" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-bsbs-accent"><h5 class="modal-title">Add Ward</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="post" asp-page-handler="AddWard">
      <div class="modal-body">
        <div class="mb-3"><label class="form-label">LGA <span class="required-star">*</span></label>
          <select name="wardLgaId" class="form-select" required>
            <option value="">– Select LGA –</option>
            @foreach (var l in Model.LGAs) { <option value="@l.Id">@l.Name</option> }
          </select></div>
        <div class="mb-3"><label class="form-label">Ward Name <span class="required-star">*</span></label>
          <input name="wardName" class="form-control" required /></div>
        <div class="mb-3"><label class="form-label">Ward Code <span class="required-star">*</span></label>
          <input name="wardCode" class="form-control" required placeholder="e.g. MKD-W01" /></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-bsbs-primary">Add Ward</button>
      </div>
    </form>
  </div></div>
</div>

<div class="modal fade" id="modalKindred" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-bsbs-accent"><h5 class="modal-title">Add Kindred</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="post" asp-page-handler="AddKindred">
      <div class="modal-body">
        <div class="mb-3"><label class="form-label">Ward <span class="required-star">*</span></label>
          <select name="kindredWardId" class="form-select" required>
            <option value="">– Select Ward –</option>
            @foreach (var w in Model.Wards) { <option value="@w.Id">@w.LocalGovernmentArea?.Name – @w.Name</option> }
          </select></div>
        <div class="mb-3"><label class="form-label">Kindred Name <span class="required-star">*</span></label>
          <input name="kindredName" class="form-control" required /></div>
        <div class="mb-3"><label class="form-label">Kindred Code <span class="required-star">*</span></label>
          <input name="kindredCode" class="form-control" required /></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-bsbs-primary">Add Kindred</button>
      </div>
    </form>
  </div></div>
</div>

<div class="modal fade" id="modalCommunity" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-bsbs-accent"><h5 class="modal-title">Add Community</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="post" asp-page-handler="AddCommunity">
      <div class="modal-body">
        <div class="mb-3"><label class="form-label">Kindred <span class="required-star">*</span></label>
          <select name="communityKindredId" class="form-select" required>
            <option value="">– Select Kindred –</option>
            @foreach (var k in Model.Kindreds)
            { <option value="@k.Id">@k.Ward?.LocalGovernmentArea?.Name / @k.Ward?.Name / @k.Name</option> }
          </select></div>
        <div class="mb-3"><label class="form-label">Community Name <span class="required-star">*</span></label>
          <input name="communityName" class="form-control" required /></div>
        <div class="mb-3"><label class="form-label">Community Code <span class="required-star">*</span></label>
          <input name="communityCode" class="form-control" required placeholder="e.g. ABG-C01" /></div>
        <div class="mb-3"><label class="form-label">Major Ethnic Groups</label>
          <input name="communityEthnic" class="form-control" placeholder="e.g. Tiv, Idoma" /></div>
        <div class="mb-3"><label class="form-label">Estimated Population</label>
          <input type="number" name="communityPop" class="form-control" min="0" /></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-bsbs-primary">Add Community</button>
      </div>
    </form>
  </div></div>
</div>

<!-- ── EDIT MODALS ── -->
@foreach (var lga in Model.LGAs)
{
<div class="modal fade" id="modalEditLGA-@lga.Id" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-bsbs-accent"><h5 class="modal-title">Edit LGA</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="post" asp-page-handler="EditLGA">
      <input type="hidden" name="editLgaId" value="@lga.Id" />
      <div class="modal-body">
        <div class="mb-3"><label class="form-label">LGA Name <span class="required-star">*</span></label>
          <input name="editLgaName" class="form-control" required value="@lga.Name" /></div>
        <div class="mb-3"><label class="form-label">LGA Code <span class="required-star">*</span></label>
          <input name="editLgaCode" class="form-control" required value="@lga.Code" /></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-bsbs-primary">Save Changes</button>
      </div>
    </form>
  </div></div>
</div>
}

@foreach (var w in Model.Wards)
{
<div class="modal fade" id="modalEditWard-@w.Id" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-bsbs-accent"><h5 class="modal-title">Edit Ward</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="post" asp-page-handler="EditWard">
      <input type="hidden" name="editWardId" value="@w.Id" />
      <div class="modal-body">
        <div class="mb-3"><label class="form-label">LGA <span class="required-star">*</span></label>
          <select name="editWardLgaId" class="form-select" required>
            @foreach (var l in Model.LGAs) { <option value="@l.Id" selected="@(l.Id == w.LocalGovernmentAreaId)">@l.Name</option> }
          </select></div>
        <div class="mb-3"><label class="form-label">Ward Name <span class="required-star">*</span></label>
          <input name="editWardName" class="form-control" required value="@w.Name" /></div>
        <div class="mb-3"><label class="form-label">Ward Code <span class="required-star">*</span></label>
          <input name="editWardCode" class="form-control" required value="@w.Code" /></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-bsbs-primary">Save Changes</button>
      </div>
    </form>
  </div></div>
</div>
}

@foreach (var k in Model.Kindreds)
{
<div class="modal fade" id="modalEditKindred-@k.Id" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-bsbs-accent"><h5 class="modal-title">Edit Kindred</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="post" asp-page-handler="EditKindred">
      <input type="hidden" name="editKindredId" value="@k.Id" />
      <div class="modal-body">
        <div class="mb-3"><label class="form-label">Ward <span class="required-star">*</span></label>
          <select name="editKindredWardId" class="form-select" required>
            @foreach (var w2 in Model.Wards) { <option value="@w2.Id" selected="@(w2.Id == k.WardId)">@w2.LocalGovernmentArea?.Name – @w2.Name</option> }
          </select></div>
        <div class="mb-3"><label class="form-label">Kindred Name <span class="required-star">*</span></label>
          <input name="editKindredName" class="form-control" required value="@k.Name" /></div>
        <div class="mb-3"><label class="form-label">Kindred Code <span class="required-star">*</span></label>
          <input name="editKindredCode" class="form-control" required value="@k.Code" /></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-bsbs-primary">Save Changes</button>
      </div>
    </form>
  </div></div>
</div>
}

@foreach (var c2 in Model.Communities)
{
<div class="modal fade" id="modalEditCommunity-@c2.Id" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-bsbs-accent"><h5 class="modal-title">Edit Community</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="post" asp-page-handler="EditCommunity">
      <input type="hidden" name="editCommunityId" value="@c2.Id" />
      <div class="modal-body">
        <div class="mb-3"><label class="form-label">Kindred <span class="required-star">*</span></label>
          <select name="editCommunityKindredId" class="form-select" required>
            @foreach (var k2 in Model.Kindreds)
            { <option value="@k2.Id" selected="@(k2.Id == c2.KindredId)">@k2.Ward?.LocalGovernmentArea?.Name / @k2.Ward?.Name / @k2.Name</option> }
          </select></div>
        <div class="mb-3"><label class="form-label">Community Name <span class="required-star">*</span></label>
          <input name="editCommunityName" class="form-control" required value="@c2.Name" /></div>
        <div class="mb-3"><label class="form-label">Community Code <span class="required-star">*</span></label>
          <input name="editCommunityCode" class="form-control" required value="@c2.Code" /></div>
        <div class="mb-3"><label class="form-label">Major Ethnic Groups</label>
          <input name="editCommunityEthnic" class="form-control" value="@c2.MajorEthnicGroups" /></div>
        <div class="mb-3"><label class="form-label">Estimated Population</label>
          <input type="number" name="editCommunityPop" class="form-control" min="0" value="@c2.EstimatedPopulation" /></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-bsbs-primary">Save Changes</button>
      </div>
    </form>
  </div></div>
</div>
}

// в”Ђв”Ђ Toggle / Delete via AJAX в”Ђв”Ђ
function getTbl(type) {
  return { LGA: tblLGA, Ward: tblWard, Kindred: tblKindred, Community: tblCommunity }[type];
}

function doToggle(type, id) {
  Swal.fire({
    title: 'Toggle Status?',
    text: `Are you sure you want to toggle this ${type}?`,
    icon: 'question',
    showCancelButton: true,
    confirmButtonColor: '#e6a817',
    cancelButtonColor: '#6c757d',
    confirmButtonText: 'Yes, toggle it'
  }).then((result) => {
    if (!result.isConfirmed) return;
    $.blockUI({ message: '<div class="d-flex align-items-center gap-2"><div class="spinner-border spinner-border-sm text-primary"></div> Processing...</div>', css: { border: 'none', padding: '15px', backgroundColor: 'rgba(255,255,255,0.9)', borderRadius: '8px', fontSize: '14px' } });
    $.ajax({
      url: '/api/home/ToggleEntity',
      type: 'POST',
      data: { type, id },
      success: function(res) {
        $.unblockUI();
        if (res.success) {
          Swal.fire({ icon: 'success', title: 'Done!', text: res.message, timer: 2000, showConfirmButton: false });
          getTbl(type)?.ajax.reload(null, false);
        } else {
          Swal.fire({ icon: 'error', title: 'Error', text: res.message });
        }
      },
      error: function() {
        $.unblockUI();
        Swal.fire({ icon: 'error', title: 'Error', text: 'An unexpected error occurred.' });
      }
    });
  });
}

function doDelete(type, id) {
  Swal.fire({
    title: `Delete this ${type}?`,
    html: `<p class="text-muted">This action cannot be undone. If other records depend on this ${type}, the deletion will be rejected.</p>`,
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#dc3545',
    cancelButtonColor: '#6c757d',
    confirmButtonText: '<i class="bi bi-trash3 me-1"></i>Yes, delete it',
    cancelButtonText: 'Cancel'
  }).then((result) => {
    if (!result.isConfirmed) return;
    $.blockUI({ message: '<div class="d-flex align-items-center gap-2"><div class="spinner-border spinner-border-sm text-danger"></div> Checking dependencies & deleting...</div>', css: { border: 'none', padding: '15px', backgroundColor: 'rgba(255,255,255,0.9)', borderRadius: '8px', fontSize: '14px' } });
    $.ajax({
      url: '/api/home/DeleteEntity',
      type: 'POST',
      data: { type, id },
      success: function(res) {
        $.unblockUI();
        if (res.success) {
          Swal.fire({ icon: 'success', title: 'Deleted!', text: res.message, timer: 2500, showConfirmButton: false });
          getTbl(type)?.ajax.reload(null, false);
        } else {
          Swal.fire({
            icon: 'error',
            title: 'Cannot Delete',
            html: `<p>${res.message}</p>`,
            confirmButtonColor: '#0d6efd'
          });
        }
      },
      error: function() {
        $.unblockUI();
        Swal.fire({ icon: 'error', title: 'Error', text: 'An unexpected error occurred.' });
      }
    });
  });
}
</script>
}

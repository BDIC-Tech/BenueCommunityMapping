        <div class="mb-3"><label class="form-label">LGA Name <span class="required-star">*</span></label>
          <input name="editLgaName" id="editLgaName" class="form-control" required /></div>
        <div class="mb-3"><label class="form-label">LGA Code <span class="required-star">*</span></label>
          <input name="editLgaCode" id="editLgaCode" class="form-control" required /></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-bsbs-primary">Save Changes</button>
      </div>
    </form>
  </div></div>
</div>

<div class="modal fade" id="modalEditWard" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-bsbs-accent"><h5 class="modal-title">Edit Ward</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="post" asp-page-handler="EditWard">
      <input type="hidden" name="editWardId" id="editWardId" />
      <div class="modal-body">
        <div class="mb-3"><label class="form-label">LGA <span class="required-star">*</span></label>
          <select name="editWardLgaId" id="editWardLgaId" class="form-select" required>
            @foreach (var l in Model.LGAs) { <option value="@l.Id">@l.Name</option> }
          </select></div>
        <div class="mb-3"><label class="form-label">Ward Name <span class="required-star">*</span></label>
          <input name="editWardName" id="editWardName" class="form-control" required /></div>
        <div class="mb-3"><label class="form-label">Ward Code <span class="required-star">*</span></label>
          <input name="editWardCode" id="editWardCode" class="form-control" required /></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-bsbs-primary">Save Changes</button>
      </div>
    </form>
  </div></div>
</div>

<div class="modal fade" id="modalEditKindred" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-bsbs-accent"><h5 class="modal-title">Edit Kindred</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="post" asp-page-handler="EditKindred">
      <input type="hidden" name="editKindredId" id="editKindredId" />
      <div class="modal-body">
        <div class="mb-3"><label class="form-label">Ward <span class="required-star">*</span></label>
          <select name="editKindredWardId" id="editKindredWardId" class="form-select" required>
            @foreach (var w in Model.Wards) { <option value="@w.Id">@w.LocalGovernmentArea?.Name Гўв‚¬вЂњ @w.Name</option> }
          </select></div>
        <div class="mb-3"><label class="form-label">Kindred Name <span class="required-star">*</span></label>
          <input name="editKindredName" id="editKindredName" class="form-control" required /></div>
        <div class="mb-3"><label class="form-label">Kindred Code <span class="required-star">*</span></label>
          <input name="editKindredCode" id="editKindredCode" class="form-control" required /></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-bsbs-primary">Save Changes</button>
      </div>
    </form>
  </div></div>
</div>

<div class="modal fade" id="modalEditCommunity" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-bsbs-accent"><h5 class="modal-title">Edit Community</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="post" asp-page-handler="EditCommunity">
      <input type="hidden" name="editCommunityId" id="editCommunityId" />
      <div class="modal-body">
        <div class="mb-3"><label class="form-label">Kindred <span class="required-star">*</span></label>
          <select name="editCommunityKindredId" id="editCommunityKindredId" class="form-select" required>
            @foreach (var k in Model.Kindreds)
            { <option value="@k.Id">@k.Ward?.LocalGovernmentArea?.Name / @k.Ward?.Name / @k.Name</option> }
          </select></div>
        <div class="mb-3"><label class="form-label">Community Name <span class="required-star">*</span></label>
          <input name="editCommunityName" id="editCommunityName" class="form-control" required /></div>
        <div class="mb-3"><label class="form-label">Community Code <span class="required-star">*</span></label>
          <input name="editCommunityCode" id="editCommunityCode" class="form-control" required /></div>
        <div class="mb-3"><label class="form-label">Major Ethnic Groups</label>
          <input name="editCommunityEthnic" id="editCommunityEthnic" class="form-control" /></div>
        <div class="mb-3"><label class="form-label">Estimated Population</label>
          <input type="number" name="editCommunityPop" id="editCommunityPop" class="form-control" min="0" /></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-bsbs-primary">Save Changes</button>
      </div>

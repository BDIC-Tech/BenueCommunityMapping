  </div></div>
</div>

<!-- Hidden action forms for toggle/delete -->
<form id="frmToggle" method="post" style="display:none">
  @Html.AntiForgeryToken()
</form>
<form id="frmDelete" method="post" style="display:none">
  @Html.AntiForgeryToken()
</form>




@section Scripts {
  <partial name="_DataTablesScriptsFiles" />
  <script src="~/libs/sweetalert2/sweetalert2.all.min.js"></script>
  <script src="~/libs/jquery.blockUI/jquery.blockUI.min.js"></script>
<script>
const PAGE = '/Admin/Geography';
const TOKEN = document.querySelector('input[name="__RequestVerificationToken"]').value;

function statusBadge(isActive) {
  return isActive
    ? '<span class="badge bg-success">Active</span>'
    : '<span class="badge bg-secondary">Inactive</span>';
}

function actionBtns(id, type) {
  const toggleIcon = `<i class="bi bi-arrow-repeat"></i>`;
  return `
  <div class="dropdown">
    <button class="btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
      <i class="bi bi-three-dots-vertical"></i>
    </button>
    <ul class="dropdown-menu">
      <li><button class="dropdown-item" type="button" onclick="openEdit${type}(${id})"><i class="bi bi-pencil-square me-2 text-primary"></i>Edit</button></li>
      <li><button class="dropdown-item" type="button" onclick="doToggle('${type}',${id})"><i class="bi bi-arrow-repeat me-2 text-warning"></i>${toggleIcon}</button></li>
      <li><button class="dropdown-item text-danger" type="button" onclick="doDelete('${type}',${id})"><i class="bi bi-trash3 me-2"></i>Delete</button></li>
    </ul>
</div>
  `;
}

function dtConfig(url, columns) {
  return {
    serverSide: true,
    processing: true,
    searching: true,
    paging: true,
    info: true,
    responsive: true,
    ajax: { url: url, type: 'POST' },
    columns: columns,
    language: { emptyTable: 'No data available', processing: '<div class="spinner-border spinner-border-sm text-primary"></div> Loading...' },
    dom: 'Bfrtip',
    buttons: ['copy','csv','excel','pdf','print']
  };
}

// ГўвЂќв‚¬ГўвЂќв‚¬ LGA DataTable ГўвЂќв‚¬ГўвЂќв‚¬
const tblLGA = new DataTable('#tblLGA', dtConfig('/api/home/GetLgas', [
  { data: 'id', name: '0' },
  { data: 'name', name: '1', render: (d) => `<strong>${d}</strong>` },
  { data: 'code', name: '2', render: (d) => `<code>${d}</code>` },
  { data: 'wardCount', name: '3', orderable: false },
  { data: 'isActive', name: '4', orderable: false, render: (d) => statusBadge(d) },
  { data: null, orderable: false, searchable: false, render: (d) => actionBtns(d.id, 'LGA') }
]));

// ГўвЂќв‚¬ГўвЂќв‚¬ Ward DataTable ГўвЂќв‚¬ГўвЂќв‚¬
const tblWard = new DataTable('#tblWard', dtConfig('/api/home/GetWards', [
  { data: 'id', name: '0' },
  { data: 'name', name: '1', render: (d) => `<strong>${d}</strong>` },
  { data: 'code', name: '2', render: (d) => `<code>${d}</code>` },
  { data: 'lgaName', name: '3' },
  { data: 'kindredCount', name: '4', orderable: false },
  { data: 'isActive', name: '5', orderable: false, render: (d) => statusBadge(d) },
  { data: null, orderable: false, searchable: false, render: (d) => actionBtns(d.id, 'Ward') }
]));

// ГўвЂќв‚¬ГўвЂќв‚¬ Kindred DataTable ГўвЂќв‚¬ГўвЂќв‚¬
const tblKindred = new DataTable('#tblKindred', dtConfig('/api/home/GetKindreds', [
  { data: 'id', name: '0' },
  { data: 'name', name: '1', render: (d) => `<strong>${d}</strong>` },
  { data: 'code', name: '2', render: (d) => `<code>${d}</code>` },
  { data: 'wardName', name: '3' },
  { data: 'lgaName', name: '4' },
  { data: 'communityCount', name: '5', orderable: false },
  { data: 'isActive', name: '6', orderable: false, render: (d) => statusBadge(d) },
  { data: null, orderable: false, searchable: false, render: (d) => actionBtns(d.id, 'Kindred') }
]));

// ГўвЂќв‚¬ГўвЂќв‚¬ Community DataTable ГўвЂќв‚¬ГўвЂќв‚¬
const tblCommunity = new DataTable('#tblCommunity', dtConfig('/api/home/GetCommunities', [
  { data: 'id', name: '0' },
  { data: 'name', name: '1', render: (d) => `<strong>${d}</strong>` },
  { data: 'code', name: '2', render: (d) => `<code>${d}</code>` },
  { data: 'kindredName', name: '3' },
  { data: 'wardName', name: '4' },
  { data: 'lgaName', name: '5' },
  { data: 'estimatedPopulation', name: '6', orderable: false, render: (d) => d ? d.toLocaleString() : 'Гўв‚¬вЂњ' },
  { data: 'submissionCount', name: '7', orderable: false, render: (d) => `<span class="badge bg-secondary rounded-pill">${d}</span>` },
  { data: 'isActive', name: '8', orderable: false, render: (d) => statusBadge(d) },
  { data: null, orderable: false, searchable: false, render: (d) => actionBtns(d.id, 'Community') }
]));

// Redraw visible table on tab switch
document.querySelectorAll('#geoTabs button[data-bs-toggle="tab"]').forEach(el => {
  el.addEventListener('shown.bs.tab', () => {
    const target = el.getAttribute('data-bs-target');
    const tbl = document.querySelector(target + ' table');
    if (tbl) DataTable.api(tbl).columns.adjust().responsive.recalc();
  });
});


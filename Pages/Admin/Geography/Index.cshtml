@page
@model BenueCommunityMapping.Pages.Admin.Geography.IndexModel
@{
    ViewData["Title"] = "Geographic Hierarchy";
}
@section Sheets{
        <link href="~/lib/sweetalert2/sweetalert2.min.css" rel="stylesheet" />
        <partial name="_DatatablesSheetFiles" />
    }

<div class="page-hero mt-3">
  <div class="hero-icon"><i class="bi bi-diagram-3-fill"></i></div>
  <div>
    <h1>Geographic Hierarchy</h1>
    <p>Manage the LGA ГўвЂ вЂ™ Ward ГўвЂ вЂ™ Kindred ГўвЂ вЂ™ Community reference data used for all submissions</p>
  </div>
</div>

<!-- STATS ROW -->
<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="stat-card">
      <div class="stat-icon green"><i class="bi bi-building"></i></div>
      <div><div class="stat-value">@Model.LGACount</div><div class="stat-label">LGAs</div></div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card">
      <div class="stat-icon blue"><i class="bi bi-grid-3x3-gap"></i></div>
      <div><div class="stat-value">@Model.WardCount</div><div class="stat-label">Wards</div></div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card">
      <div class="stat-icon gold"><i class="bi bi-people"></i></div>
      <div><div class="stat-value">@Model.KindredCount</div><div class="stat-label">Kindreds</div></div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card">
      <div class="stat-icon purple"><i class="bi bi-geo-alt-fill"></i></div>
      <div><div class="stat-value">@Model.CommunityCount</div><div class="stat-label">Communities</div></div>
    </div>
  </div>
</div>

<!-- TABS -->
<ul class="nav nav-tabs mb-0" id="geoTabs">
  <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabLGA">
    <i class="bi bi-building me-1"></i>LGAs
  </button></li>
  <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabWard">
    <i class="bi bi-grid-3x3-gap me-1"></i>Wards
  </button></li>
  <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabKindred">
    <i class="bi bi-people me-1"></i>Kindreds
  </button></li>
  <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabCommunity">
    <i class="bi bi-geo-alt-fill me-1"></i>Communities
  </button></li>
</ul>

<div class="tab-content">

  <!-- ГўвЂќв‚¬ГўвЂќв‚¬ LGA TAB ГўвЂќв‚¬ГўвЂќв‚¬ -->
  <div class="tab-pane fade show active table-card rounded-top-0" id="tabLGA">
    <div class="table-card-header">
      <h5 class="ms-1">Local Government Areas</h5>
      <button class="btn btn-bsbs-gold btn-sm ms-auto" data-bs-toggle="modal" data-bs-target="#modalLGA">
        <i class="bi bi-plus me-1"></i>Add LGA
      </button>
    </div>
    <div class="card">
      <div class="card-body">
            <table class="bsbs-table table-card table-sm" id="tblLGA" style="width:100%">
                <thead><tr><th>#</th><th>Name</th><th>Code</th><th>Wards</th><th>Status</th><th></th></tr></thead>
                <tbody></tbody>
            </table>
      </div>
    </div>
  </div>

  <!-- ГўвЂќв‚¬ГўвЂќв‚¬ WARD TAB ГўвЂќв‚¬ГўвЂќв‚¬ -->
  <div class="tab-pane fade table-card rounded-top-0" id="tabWard">
    <div class="table-card-header">
      <h5 class="ms-1">Wards</h5>
      <button class="btn btn-bsbs-gold btn-sm ms-auto" data-bs-toggle="modal" data-bs-target="#modalWard">
        <i class="bi bi-plus me-1"></i>Add Ward
      </button>
    </div>
    <div class="card">
      <div class="card-body">
          <table class="bsbs-table" id="tblWard" style="width:100%">
            <thead><tr><th>#</th><th>Ward Name</th><th>Code</th><th>LGA</th><th>Kindreds</th><th>Status</th><th></th></tr></thead>
            <tbody></tbody>
          </table>
      </div>
    </div>
  </div>

  <!-- ГўвЂќв‚¬ГўвЂќв‚¬ KINDRED TAB ГўвЂќв‚¬ГўвЂќв‚¬ -->
  <div class="tab-pane fade table-card rounded-top-0" id="tabKindred">
    <div class="table-card-header">
      <h5 class="ms-1">Kindreds</h5>
      <button class="btn btn-bsbs-gold btn-sm ms-auto" data-bs-toggle="modal" data-bs-target="#modalKindred">
        <i class="bi bi-plus me-1"></i>Add Kindred
      </button>
    </div>
    <div class="card">
        <div class="card-body">
            <table class="bsbs-table" id="tblKindred" style="width:100%">
            <thead><tr><th>#</th><th>Kindred</th><th>Code</th><th>Ward</th><th>LGA</th><th>Communities</th><th>Status</th><th></th></tr></thead>
            <tbody></tbody>
            </table>
        </div>
    </div>
  </div>

  <!-- ГўвЂќв‚¬ГўвЂќв‚¬ COMMUNITY TAB ГўвЂќв‚¬ГўвЂќв‚¬ -->
  <div class="tab-pane fade table-card rounded-top-0" id="tabCommunity">
    <div class="table-card-header">
      <h5 class="ms-1">Communities</h5>
      <button class="btn btn-bsbs-gold btn-sm ms-auto" data-bs-toggle="modal" data-bs-target="#modalCommunity">
        <i class="bi bi-plus me-1"></i>Add Community
      </button>
    </div>
    <div class="card">
      <div class="card-body">
      <table class="bsbs-table" id="tblCommunity" style="width:100%">
        <thead><tr><th>#</th><th>Community</th><th>Code</th><th>Kindred</th><th>Ward</th><th>LGA</th><th>Pop.</th><th>Submissions</th><th>Status</th><th></th></tr></thead>
        <tbody></tbody>
      </table>
      </div>
    </div>
  </div>
</div>

<!-- ГўвЂќв‚¬ГўвЂќв‚¬ MODALS ГўвЂќв‚¬ГўвЂќв‚¬ -->
<div class="modal fade" id="modalLGA" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-bsbs-accent"><h5 class="modal-title">Add Local Government Area</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="post" asp-page-handler="AddLGA">
      <div class="modal-body">
        <div class="mb-3"><label class="form-label">LGA Name <span class="required-star">*</span></label>
          <input name="lgaName" class="form-control" required placeholder="e.g. Makurdi" /></div>
        <div class="mb-3"><label class="form-label">LGA Code <span class="required-star">*</span></label>
          <input name="lgaCode" class="form-control" required placeholder="e.g. BN-MKD" /></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-bsbs-primary">Add LGA</button>
      </div>
    </form>
  </div></div>
</div>

<div class="modal fade" id="modalWard" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-bsbs-accent"><h5 class="modal-title">Add Ward</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="post" asp-page-handler="AddWard">
      <div class="modal-body">
        <div class="mb-3"><label class="form-label">LGA <span class="required-star">*</span></label>
          <select name="wardLgaId" class="form-select" required>
            <option value="">Гўв‚¬вЂњ Select LGA Гўв‚¬вЂњ</option>
            @foreach (var l in Model.LGAs) { <option value="@l.Id">@l.Name</option> }
          </select></div>
        <div class="mb-3"><label class="form-label">Ward Name <span class="required-star">*</span></label>
          <input name="wardName" class="form-control" required /></div>
        <div class="mb-3"><label class="form-label">Ward Code <span class="required-star">*</span></label>
          <input name="wardCode" class="form-control" required placeholder="e.g. MKD-W01" /></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-bsbs-primary">Add Ward</button>
      </div>
    </form>
  </div></div>
</div>

<div class="modal fade" id="modalKindred" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-bsbs-accent"><h5 class="modal-title">Add Kindred</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="post" asp-page-handler="AddKindred">
      <div class="modal-body">
        <div class="mb-3"><label class="form-label">Ward <span class="required-star">*</span></label>
          <select name="kindredWardId" class="form-select" required>
            <option value="">Гўв‚¬вЂњ Select Ward Гўв‚¬вЂњ</option>
            @foreach (var w in Model.Wards) { <option value="@w.Id">@w.LocalGovernmentArea?.Name Гўв‚¬вЂњ @w.Name</option> }
          </select></div>
        <div class="mb-3"><label class="form-label">Kindred Name <span class="required-star">*</span></label>
          <input name="kindredName" class="form-control" required /></div>
        <div class="mb-3"><label class="form-label">Kindred Code <span class="required-star">*</span></label>
          <input name="kindredCode" class="form-control" required /></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-bsbs-primary">Add Kindred</button>
      </div>
    </form>
  </div></div>
</div>

<div class="modal fade" id="modalCommunity" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-bsbs-accent"><h5 class="modal-title">Add Community</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="post" asp-page-handler="AddCommunity">
      <div class="modal-body">
        <div class="mb-3"><label class="form-label">Kindred <span class="required-star">*</span></label>
          <select name="communityKindredId" class="form-select" required>
            <option value="">Гўв‚¬вЂњ Select Kindred Гўв‚¬вЂњ</option>
            @foreach (var k in Model.Kindreds)
            { <option value="@k.Id">@k.Ward?.LocalGovernmentArea?.Name / @k.Ward?.Name / @k.Name</option> }
          </select></div>
        <div class="mb-3"><label class="form-label">Community Name <span class="required-star">*</span></label>
          <input name="communityName" class="form-control" required /></div>
        <div class="mb-3"><label class="form-label">Community Code <span class="required-star">*</span></label>
          <input name="communityCode" class="form-control" required placeholder="e.g. ABG-C01" /></div>
        <div class="mb-3"><label class="form-label">Major Ethnic Groups</label>
          <input name="communityEthnic" class="form-control" placeholder="e.g. Tiv, Idoma" /></div>
        <div class="mb-3"><label class="form-label">Estimated Population</label>
          <input type="number" name="communityPop" class="form-control" min="0" /></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-bsbs-primary">Add Community</button>
      </div>
    </form>
  </div></div>
</div>

<!-- ГўвЂќв‚¬ГўвЂќв‚¬ REUSABLE EDIT MODALS ГўвЂќв‚¬ГўвЂќв‚¬ -->
<div class="modal fade" id="modalEditLGA" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header bg-bsbs-accent"><h5 class="modal-title">Edit LGA</h5>
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="post" asp-page-handler="EditLGA">
      <input type="hidden" name="editLgaId" id="editLgaId" />

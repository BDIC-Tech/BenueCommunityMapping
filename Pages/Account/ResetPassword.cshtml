@page
@model BenueCommunityMapping.Pages.Account.ResetPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Reset Password – BSBS Community Mapping";
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"]</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    body {
      background: #0e1e12;
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      padding: 24px;
    }
    .card-wrap {
      background: #fff;
      border-radius: 16px;
      overflow: hidden;
      max-width: 460px; width: 100%;
      box-shadow: 0 20px 60px rgba(0,0,0,.45);
    }
    .card-header-custom {
      background: linear-gradient(135deg, #0e1e12, #18301d);
      padding: 2.2rem 2rem 1.8rem;
      text-align: center;
      border-bottom: 4px solid #c8931a;
    }
    .header-icon {
      width: 64px; height: 64px; border-radius: 50%;
      background: rgba(255,255,255,0.18);
      border: 2px solid rgba(255,255,255,0.30);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.8rem; margin: 0 auto 1rem;
    }
    .card-header-custom h1 {
      font-family: 'Playfair Display', serif;
      color: #fff; font-size: 1.3rem; margin: 0;
    }
    .card-header-custom p { color: #a8c4b0; font-size: .82rem; margin: .3rem 0 0; }
    .card-body-custom { padding: 2rem; }

    /* password strength bar */
    #strength-bar { height: 5px; border-radius: 3px; transition: all .3s; }
    #strength-label { font-size: .75rem; }

    .form-control:focus { border-color: #1a6b3a; box-shadow: 0 0 0 3px rgba(26,107,58,.12); }
    .btn-primary-custom {
      background: linear-gradient(135deg, #1a6b3a, #18301d);
      color: #fff; border: none; font-weight: 700;
      width: 100%; padding: .75rem; border-radius: 8px;
      font-size: .95rem; letter-spacing: .3px;
    }
    .btn-primary-custom:hover { opacity: .9; color: #fff; }
    .input-group-text { background: #f4f7f5; border-color: #d0ddd4; cursor: pointer; }
    .back-link { display: block; text-align: center; margin-top: 1.2rem; font-size: .88rem; color: #6b7280; }
    .back-link a { color: #1a6b3a; text-decoration: none; font-weight: 600; }
    .back-link a:hover { text-decoration: underline; }
    /* Success/error states */
    .result-box { border-radius: 10px; padding: 1.2rem 1.4rem; text-align: center; }
    .result-box .result-icon { font-size: 2.5rem; margin-bottom: .6rem; }
    .result-success { background: #f0fdf4; border: 1px solid #86efac; color: #166534; }
    .result-error   { background: #fef2f2; border: 1px solid #fca5a5; color: #991b1b; }
    .req-hint {
      background: #e8f4ec; border-radius: 8px;
      padding: .75rem 1rem; font-size: .82rem; color: #1a6b3a;
    }
  </style>
</head>
<body>
  <div class="card-wrap">

    <div class="card-header-custom">
      <div class="header-icon">&#128273;</div>
      <h1>Reset Password</h1>
      <p>Choose a new secure password for your account</p>
    </div>

    <div class="card-body-custom">

      @if (Model.InvalidLink)
      {
        <div class="result-box result-error">
          <div class="result-icon">&#10060;</div>
          <strong>Invalid or Expired Link</strong>
          <p class="mt-2 mb-0" style="font-size:.9rem;">
            This password reset link has expired or is invalid.<br/>
            Please request a new one.
          </p>
        </div>
        <div class="back-link mt-3">
          <a href="/Account/ForgotPassword"><i class="bi bi-arrow-repeat me-1"></i>Request New Link</a>
        </div>
      }
      else if (Model.ResetSucceeded)
      {
        <div class="result-box result-success">
          <div class="result-icon">&#9989;</div>
          <strong>Password Reset Successful!</strong>
          <p class="mt-2 mb-0" style="font-size:.9rem;">
            Your password has been updated. You can now log in with your new credentials.
          </p>
        </div>
        <div class="back-link mt-3">
          <a href="/Account/Login"><i class="bi bi-box-arrow-in-right me-1"></i>Go to Login</a>
        </div>
      }
      else
      {
        <form method="post">
          <!-- Hidden fields carrying the token from the email link -->
          <input type="hidden" asp-for="Input.UserId" />
          <input type="hidden" asp-for="Input.Token" />

          <div asp-validation-summary="ModelOnly"
               class="alert alert-danger py-2 mb-3"
               style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

          <!-- New Password -->
          <div class="mb-3">
            <label asp-for="Input.NewPassword" class="form-label fw-semibold">New Password</label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-lock"></i></span>
              <input asp-for="Input.NewPassword" id="newPassword" class="form-control"
                     placeholder="Minimum 8 characters" type="password"
                     autocomplete="new-password"
                     oninput="checkStrength(this.value)" />
              <span class="input-group-text" onclick="toggleVis('newPassword',this)">
                <i class="bi bi-eye" id="newPassword-icon"></i>
              </span>
            </div>
            <div class="mt-1 mb-1">
              <div id="strength-bar" class="bg-secondary w-0" style="width:0%"></div>
            </div>
            <span id="strength-label" class="text-muted"></span>
            <span asp-validation-for="Input.NewPassword" class="text-danger small d-block mt-1"></span>
          </div>

          <!-- Confirm Password -->
          <div class="mb-4">
            <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold">Confirm Password</label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
              <input asp-for="Input.ConfirmPassword" id="confirmPassword" class="form-control"
                     placeholder="Repeat your password" type="password"
                     autocomplete="new-password" />
              <span class="input-group-text" onclick="toggleVis('confirmPassword',this)">
                <i class="bi bi-eye" id="confirmPassword-icon"></i>
              </span>
            </div>
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
          </div>

          <!-- Requirements hint -->
          <div class="mb-4 req-hint">
            <i class="bi bi-info-circle me-1"></i>
            <strong>Password requirements:</strong> at least 8 characters, one uppercase letter,
            one digit, and one special character.
          </div>

          <button type="submit" class="btn btn-primary-custom">
            <i class="bi bi-shield-lock me-2"></i>Reset Password
          </button>
        </form>

        <div class="back-link">
          <a href="/Account/Login"><i class="bi bi-arrow-left me-1"></i>Back to Login</a>
        </div>
      }

    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function toggleVis(id, btn) {
      const input = document.getElementById(id);
      const icon  = document.getElementById(id + '-icon');
      if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'bi bi-eye-slash';
      } else {
        input.type = 'password';
        icon.className = 'bi bi-eye';
      }
    }

    function checkStrength(val) {
      const bar   = document.getElementById('strength-bar');
      const label = document.getElementById('strength-label');
      let score = 0;
      if (val.length >= 8)                        score++;
      if (/[A-Z]/.test(val))                      score++;
      if (/[0-9]/.test(val))                      score++;
      if (/[^A-Za-z0-9]/.test(val))               score++;

      const levels = [
        { pct: '0%',   cls: 'bg-secondary', text: '' },
        { pct: '25%',  cls: 'bg-danger',    text: 'Weak' },
        { pct: '50%',  cls: 'bg-warning',   text: 'Fair' },
        { pct: '75%',  cls: 'bg-info',      text: 'Good' },
        { pct: '100%', cls: 'bg-success',   text: 'Strong' },
      ];
      const l = levels[score];
      bar.style.width = l.pct;
      bar.className   = `${l.cls}`;
      bar.style.height = '5px';
      bar.style.borderRadius = '3px';
      bar.style.transition = 'all .3s';
      label.textContent = l.text;
      label.style.color = score < 2 ? '#dc2626' : score < 4 ? '#d97706' : '#16a34a';
    }
  </script>
</body>
</html>

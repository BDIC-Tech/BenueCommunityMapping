@page
@model BenueCommunityMapping.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="page-hero mt-3">
  <div class="hero-icon"><i class="bi bi-person-circle"></i></div>
  <div>
    <h1>My Profile</h1>
    <p>Update your personal details and contact information</p>
  </div>
</div>

<div class="row">
  <div class="col-lg-6">
    <div class="content-card">
      <div class="content-card-header">
        <i class="bi bi-person-fill"></i>
        <h5>Personal Details</h5>
      </div>
      <div class="content-card-body">
        <form method="post">
          <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>

          <div class="mb-3">
            <label class="form-label text-muted">Email Address (read-only)</label>
            <input type="email" class="form-control" value="@Model.Email" disabled />
          </div>

          <div class="row g-3">
            <div class="col-md-6">
              <label asp-for="Input.FirstName" class="form-label">First Name <span class="required-star">*</span></label>
              <input asp-for="Input.FirstName" class="form-control" />
              <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="Input.LastName" class="form-label">Last Name <span class="required-star">*</span></label>
              <input asp-for="Input.LastName" class="form-control" />
              <span asp-validation-for="Input.LastName" class="text-danger small"></span>
            </div>
            <div class="col-12">
              <label asp-for="Input.PhoneNumber" class="form-label">Phone Number</label>
              <input asp-for="Input.PhoneNumber" class="form-control" placeholder="08XX XXX XXXX" />
              <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
            </div>
          </div>

          <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-bsbs-primary">
              <i class="bi bi-floppy me-1"></i>Save Changes
            </button>
            <a asp-page="/Account/ChangePassword" class="btn btn-bsbs-outline">
              <i class="bi bi-key me-1"></i>Change Password
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="content-card">
      <div class="content-card-header">
        <i class="bi bi-info-circle"></i>
        <h5>Account Information</h5>
      </div>
      <div class="content-card-body">
        <dl class="row mb-0">
          <dt class="col-sm-5 text-muted">Account Email</dt>
          <dd class="col-sm-7">@Model.Email</dd>
          <dt class="col-sm-5 text-muted">Role</dt>
          <dd class="col-sm-7">
            <span class="role-badge role-@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value?.ToLower()">
              @User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value
            </span>
          </dd>
        </dl>
        <div class="info-note mt-3">
          <i class="bi bi-shield-lock me-1"></i>
          To change your email address, contact your system administrator.
        </div>
      </div>
    </div>
  </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }

@page
@model BenueCommunityMapping.Pages.Account.ResendVerificationModel
@{
    Layout = null;
    ViewData["Title"] = "Resend Verification Email";
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Resend Verification – BSBS Community Mapping</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    body { background: #0e1e12; font-family: 'DM Sans', sans-serif; min-height: 100vh; display:flex; align-items:center; justify-content:center; }
    .login-card { background:#fff; border-radius:16px; overflow:hidden; max-width:440px; width:100%; box-shadow: 0 20px 60px rgba(0,0,0,.4); }
    .login-header { background: linear-gradient(135deg, #0e1e12, #1e3a24); padding: 2rem; text-align:center; border-bottom: 4px solid #c8931a; }
    .login-seal { width:64px;height:64px;border-radius:50%;background:#c8931a;display:flex;align-items:center;justify-content:center;font-size:1.8rem;color:#0e1e12;margin:0 auto 1rem; }
    .login-header h1 { font-family:'Playfair Display',serif; color:#fff; font-size:1.25rem; margin:0; }
    .login-header p { color:#a8c4b0; font-size:.8rem; margin:.25rem 0 0; }
    .login-body { padding:2rem; }
    .form-control:focus { border-color:#1a6b3a; box-shadow:0 0 0 3px rgba(26,107,58,.12); }
    .btn-login { background:#1a6b3a; color:#fff; border:none; font-weight:700; width:100%; padding:.7rem; border-radius:8px; font-size:.95rem; }
    .btn-login:hover { background:#155730; color:#fff; }
    .input-group-text { background:#f4f7f5; border-color:#d0ddd4; }
  </style>
</head>
<body>
<div class="login-card">
  <div class="login-header">
    <div class="login-seal"><i class="bi bi-envelope-paper"></i></div>
    <h1>Resend Verification</h1>
    <p>Benue State Bureau of Statistics – Field Data System</p>
  </div>
  <div class="login-body">
    <form method="post">
      <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

      @if (TempData["Success"] != null)
      {
          <div class="alert alert-success py-2 mb-3">
              <i class="bi bi-check-circle me-1"></i>@TempData["Success"]
          </div>
      }

      <div class="mb-4">
        <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-envelope"></i></span>
          <input asp-for="Email" class="form-control" placeholder="your@email.ng" autocomplete="username" />
        </div>
        <span asp-validation-for="Email" class="text-danger small"></span>
      </div>

      <button type="submit" class="btn btn-login mb-3">
        <i class="bi bi-send-check me-2"></i>Resend Email
      </button>

      <div class="text-center mt-3">
        <a href="/Account/Login" style="font-size:.85rem;color:#1a6b3a;text-decoration:none;font-weight:600;">
          <i class="bi bi-arrow-left me-1"></i>Back to Login
        </a>
      </div>
    </form>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

@page
@model BenueCommunityMapping.Pages.Account.ForgotPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Forgot Password – BSBS Community Mapping";
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"]</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    body {
      background: #0e1e12;
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      padding: 24px;
    }
    .card-wrap {
      background: #fff;
      border-radius: 16px;
      overflow: hidden;
      max-width: 440px; width: 100%;
      box-shadow: 0 20px 60px rgba(0,0,0,.45);
    }
    .card-header-custom {
      background: linear-gradient(135deg, #0e1e12, #18301d);
      padding: 2.2rem 2rem 1.8rem;
      text-align: center;
      border-bottom: 4px solid #c8931a;
    }
    .header-icon {
      width: 64px; height: 64px; border-radius: 50%;
      background: rgba(255,255,255,0.18);
      border: 2px solid rgba(255,255,255,0.30);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.8rem; margin: 0 auto 1rem;
    }
    .card-header-custom h1 {
      font-family: 'Playfair Display', serif;
      color: #fff; font-size: 1.3rem; margin: 0;
    }
    .card-header-custom p { color: #a8c4b0; font-size: .82rem; margin: .3rem 0 0; }
    .card-body-custom { padding: 2rem; }
    .form-control:focus { border-color: #1a6b3a; box-shadow: 0 0 0 3px rgba(26,107,58,.12); }
    .btn-primary-custom {
      background: linear-gradient(135deg, #1a6b3a, #18301d);
      color: #fff; border: none; font-weight: 700;
      width: 100%; padding: .75rem; border-radius: 8px;
      font-size: .95rem; letter-spacing: .3px;
    }
    .btn-primary-custom:hover { opacity: .9; color: #fff; }
    .input-group-text { background: #f4f7f5; border-color: #d0ddd4; }
    .back-link { display: block; text-align: center; margin-top: 1.2rem; font-size: .88rem; color: #6b7280; }
    .back-link a { color: #1a6b3a; text-decoration: none; font-weight: 600; }
    .back-link a:hover { text-decoration: underline; }
    /* Success state */
    .success-box {
      background: #f0fdf4; border: 1px solid #86efac;
      border-radius: 10px; padding: 1.2rem 1.4rem;
      text-align: center; color: #166534;
    }
    .success-box .icon { font-size: 2.5rem; margin-bottom: .6rem; }
  </style>
</head>
<body>
  <div class="card-wrap">

    <div class="card-header-custom">
      <div class="header-icon">&#128274;</div>
      <h1>Forgot Password</h1>
      <p>BSBS Community Mapping – Account Recovery</p>
    </div>

    <div class="card-body-custom">

      @if (Model.EmailSent)
      {
        <!-- ── Success state ── -->
        <div class="success-box">
          <div class="icon">&#9989;</div>
          <strong>Check your inbox!</strong>
          <p class="mt-2 mb-0" style="font-size:.9rem;">
            A password reset link has been sent to
            <strong>@Model.SentToEmail</strong>.<br/>
            Please check your email and follow the instructions.
            The link expires in <strong>2 hours</strong>.
          </p>
        </div>
        <div class="back-link mt-3">
          <a href="/Account/Login"><i class="bi bi-arrow-left me-1"></i>Back to Login</a>
        </div>
      }
      else
      {
        <!-- ── Request form ── -->
        <p class="text-muted mb-4" style="font-size:.9rem;">
          Enter the email address associated with your account and we will
          send you a link to reset your password.
        </p>

        <form method="post">
          <div asp-validation-summary="ModelOnly"
               class="alert alert-danger py-2 mb-3"
               style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

          <div class="mb-4">
            <label asp-for="Input.Email" class="form-label fw-semibold">Email Address</label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-envelope"></i></span>
              <input asp-for="Input.Email" class="form-control"
                     placeholder="your@email.ng" autocomplete="email" />
            </div>
            <span asp-validation-for="Input.Email" class="text-danger small"></span>
          </div>

          <button type="submit" class="btn btn-primary-custom">
            <i class="bi bi-send me-2"></i>Send Reset Link
          </button>
        </form>

        <div class="back-link">
          <a href="/Account/Login"><i class="bi bi-arrow-left me-1"></i>Back to Login</a>
        </div>
      }

    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

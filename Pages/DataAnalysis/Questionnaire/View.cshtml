@page "{id:guid}"
@model BenueCommunityMapping.Pages.DataAnalysis.Questionnaire.ViewModel
@using BenueCommunityMapping.Models
@{
    ViewData["Title"] = "View Submission";
    var s = Model.Submission;
    }

<div class="page-hero mt-3">
  <div class="hero-icon"><i class="bi bi-file-earmark-text"></i></div>
  <div>
    <h1>@s.Community?.Name</h1>
    <p>@(s.Community?.Kindred?.Ward?.LocalGovernmentArea?.Name) &mdash; @(s.Community?.Kindred?.Ward?.Name) &bull; Submitted by @s.Agent?.FullName</p>
  </div>
  <div class="ms-auto d-flex align-items-center gap-2">
    <span class="status-badge status-@s.Status.ToString().ToLower()">@s.Status</span>

    @if (s.Status == SubmissionStatus.Draft && User.IsInRole("Agent"))
    {
      <a asp-page="Edit" asp-route-id="@s.Id" class="btn btn-bsbs-primary btn-sm">
        <i class="bi bi-pencil me-1"></i>Edit
      </a>
    }

    @if ((s.Status == SubmissionStatus.Submitted) && User.IsInRole("Coordinator"))
    {
      <form method="post" asp-page-handler="Review" asp-route-id="@s.Id">
        <button class="btn btn-bsbs-primary btn-sm">
          <i class="bi bi-check2 me-1"></i>Mark Reviewed
        </button>
      </form>
    }

    @if ((s.Status == SubmissionStatus.ReviewedByCoordinator ||
          s.Status == SubmissionStatus.Submitted) && User.IsInRole("Admin"))
    {
      <form method="post" asp-page-handler="Approve" asp-route-id="@s.Id" class="d-inline">
        <button class="btn btn-bsbs-primary btn-sm">
          <i class="bi bi-check2-circle me-1"></i>Approve
        </button>
      </form>
      <form method="post" asp-page-handler="Reject" asp-route-id="@s.Id" class="d-inline"
            onsubmit="return confirm('Reject this submission?')">
        <button class="btn btn-outline-danger btn-sm">
          <i class="bi bi-x-circle me-1"></i>Reject
        </button>
      </form>
    }
  </div>
</div>

<!-- Notes banner -->
@if (!string.IsNullOrEmpty(s.CoordinatorNotes) || !string.IsNullOrEmpty(s.AdminNotes))
{
  <div class="row g-3 mb-3">
    @if (!string.IsNullOrEmpty(s.CoordinatorNotes))
    {
      <div class="col-md-6">
        <div class="info-note"><i class="bi bi-person-gear me-1"></i><strong>Coordinator Notes:</strong> @s.CoordinatorNotes</div>
      </div>
    }
    @if (!string.IsNullOrEmpty(s.AdminNotes))
    {
      <div class="col-md-6">
        <div class="info-note" style="border-left-color:var(--bsbs-gold);background:#fef9ec">
          <i class="bi bi-shield-fill me-1"></i><strong>Admin Notes:</strong> @s.AdminNotes
        </div>
      </div>
    }
  </div>
}

<!-- ACCORDION SECTIONS -->
<div class="accordion" id="viewAccordion">

  @* ── SECTION A ── *@
  <partial name="_ViewSectionA" model="@s" />

  @* ── SECTION B ── *@
  <partial name="_ViewSectionB" model="@s" />

  @* ── SECTION C ── *@
  <partial name="_ViewSectionC" model="@s" />

  @* ── SECTION D ── *@
  <partial name="_ViewSectionD" model="@s" />

  @* ── SECTION E ── *@
  <partial name="_ViewSectionE" model="@s" />

  @* ── SECTION F ── *@
  <partial name="_ViewSectionF" model="@s" />

  @* ── SECTION G ── *@
  <partial name="_ViewSectionG" model="@s" />

  @* ── SECTION H ── *@
  <partial name="_ViewSectionH" model="@s" />

  @* ── SECTION I ── *@
  <partial name="_ViewSectionI" model="@s" />

  @* ── SECTION J ── *@
  <partial name="_ViewSectionJ" model="@s" />

  @* ── SECTION K ── *@
  <partial name="_ViewSectionK" model="@s" />

  @* ── CONSENT ── *@
  <partial name="_ViewConsent" model="@s" />

</div>

<div class="d-flex justify-content-between mt-4">
  <a asp-page="/Agent/MySubmissions" class="btn btn-bsbs-outline">
    <i class="bi bi-arrow-left me-1"></i>Back to List
  </a>
  <small class="text-muted align-self-center">
    Created: @s.CreatedAt.ToString("dd MMM yyyy HH:mm")
    @if (s.SubmittedAt.HasValue) { <span> &bull; Submitted: @s.SubmittedAt.Value.ToString("dd MMM yyyy HH:mm")</span> }
  </small>
</div>

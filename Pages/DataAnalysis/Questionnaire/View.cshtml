@page "{id:guid}"
@model BenueCommunityMapping.Pages.DataAnalysis.Questionnaire.ViewModel
@using BenueCommunityMapping.Models
@{
    ViewData["Title"] = "View Submission";
    var s = Model.Submission;
    }

<div class="page-hero mt-3">
  <div class="hero-icon"><i class="bi bi-file-earmark-text"></i></div>
  <div>
    <h1>@s.Community?.Name</h1>
    <p>@(s.Community?.Kindred?.Ward?.LocalGovernmentArea?.Name) &mdash; @(s.Community?.Kindred?.Ward?.Name) &bull; Submitted by @s.Agent?.FullName</p>
  </div>
  <div class="ms-auto d-flex align-items-center gap-2">
    <span class="status-badge status-@s.Status.ToString().ToLower()">@s.Status</span>

    @if ((s.Status == SubmissionStatus.Draft || s.Status == SubmissionStatus.Rejected) && User.IsInRole("Agent"))
    {
      <a asp-page="Edit" asp-route-id="@s.Id" class="btn btn-bsbs-primary btn-sm">
        <i class="bi bi-pencil me-1"></i>Edit
      </a>
    }

    @if ((s.Status == SubmissionStatus.Submitted) && User.IsInRole("Coordinator"))
    {
      <form method="post" asp-page-handler="Review" asp-route-id="@s.Id" class="d-inline">
        <button class="btn btn-bsbs-primary btn-sm">
          <i class="bi bi-check2 me-1"></i>Mark Reviewed
        </button>
      </form>
      <form method="post" asp-page-handler="Reject" asp-route-id="@s.Id" class="d-inline"
            onsubmit="return confirmReject(this)">
        <button class="btn btn-outline-danger btn-sm">
          <i class="bi bi-x-circle me-1"></i>Reject
        </button>
      </form>
    }

    @if ((s.Status == SubmissionStatus.ReviewedByCoordinator ||
          s.Status == SubmissionStatus.Submitted) && User.IsInRole("Admin"))
    {
      <form method="post" asp-page-handler="Approve" asp-route-id="@s.Id" class="d-inline">
        <button class="btn btn-bsbs-primary btn-sm">
          <i class="bi bi-check2-circle me-1"></i>Approve
        </button>
      </form>
      <form method="post" asp-page-handler="Reject" asp-route-id="@s.Id" class="d-inline"
            onsubmit="return confirmReject(this)">
        <button class="btn btn-outline-danger btn-sm">
          <i class="bi bi-x-circle me-1"></i>Reject
        </button>
      </form>
    }
  </div>
</div>

<!-- Notes banner -->
@if (!string.IsNullOrEmpty(s.CoordinatorNotes) || !string.IsNullOrEmpty(s.AdminNotes))
{
  <div class="row g-3 mb-3">
    @if (!string.IsNullOrEmpty(s.CoordinatorNotes))
    {
      <div class="col-md-6">
        <div class="info-note"><i class="bi bi-person-gear me-1"></i><strong>Coordinator Notes:</strong> @s.CoordinatorNotes</div>
      </div>
    }
    @if (!string.IsNullOrEmpty(s.AdminNotes))
    {
      <div class="col-md-6">
        <div class="info-note" style="border-left-color:var(--bsbs-gold);background:#fef9ec">
          <i class="bi bi-shield-fill me-1"></i><strong>Admin Notes:</strong> @s.AdminNotes
        </div>
      </div>
    }
  </div>
}

<!-- ACCORDION SECTIONS -->
<div class="accordion" id="viewAccordion">

  @* ── SECTION A ── *@
  <partial name="_ViewSectionA" model="@s" />

  @* ── SECTION B ── *@
  <partial name="_ViewSectionB" model="@s" />

  @* ── SECTION C ── *@
  <partial name="_ViewSectionC" model="@s" />

  @* ── SECTION D ── *@
  <partial name="_ViewSectionD" model="@s" />

  @* ── SECTION E ── *@
  <partial name="_ViewSectionE" model="@s" />

  @* ── SECTION F ── *@
  <partial name="_ViewSectionF" model="@s" />

  @* ── SECTION G ── *@
  <partial name="_ViewSectionG" model="@s" />

  @* ── SECTION H ── *@
  <partial name="_ViewSectionH" model="@s" />

  @* ── SECTION I ── *@
  <partial name="_ViewSectionI" model="@s" />

  @* ── SECTION J ── *@
  <partial name="_ViewSectionJ" model="@s" />

  @* ── SECTION K ── *@
  <partial name="_ViewSectionK" model="@s" />

  @* ── CONSENT ── *@
  <partial name="_ViewConsent" model="@s" />

</div>

<!-- WORKFLOW HISTORY / AUDIT TRAIL -->
<div class="content-card mt-4 mb-3">
  <div class="content-card-header bg-dark text-white">
    <i class="bi bi-clock-history"></i>
    <h5 class="ms-2 mb-0 d-inline-block">Workflow History & Audit Trail</h5>
  </div>
  <div class="content-card-body">
    @if (s.WorkflowHistory == null || !s.WorkflowHistory.Any())
    {
      <p class="text-muted mb-0 small">No workflow actions have been recorded yet.</p>
    }
    else
    {
      <div class="position-relative ps-4 border-start border-2 border-light ms-2">
        @foreach (var history in s.WorkflowHistory.OrderBy(h => h.CreatedAt))
        {
          var dotColor = history.Action switch
          {
              "Rejected" => "border-danger bg-danger",
              "Approved" => "border-success bg-success",
              "Reviewed" => "border-warning bg-warning",
              _ => "border-primary bg-primary"
          };
          var badgeClass = history.Action switch
          {
              "Rejected" => "bg-danger text-white",
              "Approved" => "bg-success text-white",
              "Reviewed" => "bg-warning text-dark",
              _ => "bg-primary text-white"
          };

          <div class="mb-3 position-relative">
            <!-- Timeline dot -->
            <div class="position-absolute rounded-circle border border-2 @dotColor"
                 style="width: 12px; height: 12px; left: -32px; top: 6px;"></div>
            
            <div class="d-flex justify-content-between align-items-center flex-wrap">
              <div>
                <strong class="text-dark">@(history.Actor?.FullName ?? "System")</strong> 
                <span class="text-muted small">(@history.ActorRole)</span> 
                performed action <span class="badge rounded-pill @badgeClass">@history.Action</span>
              </div>
              <span class="text-muted small">@history.CreatedAt.ToString("dd MMM yyyy HH:mm:ss")</span>
            </div>
            @if (!string.IsNullOrEmpty(history.Comments))
            {
              <div class="info-note mt-2 py-1 px-3 mb-0" style="border-left-color: @(history.Action == "Rejected" ? "var(--bsbs-red)" : "var(--bsbs-green)"); background: #fdfefd; color: #333; font-style: italic;">
                <i class="bi bi-chat-right-text me-1 text-muted"></i>
                <strong>Comment:</strong> @history.Comments
              </div>
            }
          </div>
        }
      </div>
    }
  </div>
</div>

<div class="d-flex justify-content-between mt-4">
  <a asp-page="/Agent/MySubmissions" class="btn btn-bsbs-outline">
    <i class="bi bi-arrow-left me-1"></i>Back to List
  </a>
  <small class="text-muted align-self-center">
    Created: @s.CreatedAt.ToString("dd MMM yyyy HH:mm")
    @if (s.SubmittedAt.HasValue) { <span> &bull; Submitted: @s.SubmittedAt.Value.ToString("dd MMM yyyy HH:mm")</span> }
  </small>
</div>

@section Scripts {
  <link href="~/libs/sweetalert2/sweetalert2.min.css" rel="stylesheet" />
  <script src="~/libs/sweetalert2/sweetalert2.all.min.js"></script>
  <script>
    function confirmReject(form) {
      Swal.fire({
        title: 'Reject Questionnaire?',
        text: 'Please provide a mandatory reason for rejecting this questionnaire:',
        input: 'textarea',
        inputPlaceholder: 'Type your rejection reason here...',
        showCancelButton: true,
        confirmButtonColor: '#dc3545',
        cancelButtonColor: '#6c757d',
        confirmButtonText: '<i class="bi bi-x-circle me-1"></i>Yes, Reject',
        cancelButtonText: 'Cancel',
        inputValidator: (value) => {
          if (!value || !value.trim()) {
            return 'You must enter a rejection reason!';
          }
        }
      }).then((result) => {
        if (result.isConfirmed) {
          let input = form.querySelector('input[name="reason"]');
          if (!input) {
            input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'reason';
            form.appendChild(input);
          }
          input.value = result.value.trim();
          form.submit();
        }
      });
      return false;
    }
  </script>
}

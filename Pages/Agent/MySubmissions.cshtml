@page
@model BenueCommunityMapping.Pages.Agent.MySubmissionsModel
@{
    ViewData["Title"] = "My Submissions";
}

<div class="page-hero mt-3">
  <div class="hero-icon"><i class="bi bi-journal-text"></i></div>
  <div>
    <h1>My Submissions</h1>
    <p>Questionnaire entries you have collected in the field</p>
  </div>
  <a asp-page="/Questionnaire/Create" class="btn btn-bsbs-gold ms-auto">
    <i class="bi bi-plus-circle me-1"></i>New Entry
  </a>
</div>

<!-- FILTER BAR -->
<div class="content-card mb-3">
  <div class="content-card-body py-2">
    <form method="get" class="row g-2 align-items-end">
      <div class="col-md-5">
        <label class="form-label mb-1">Search</label>
        <div class="input-group input-group-sm">
          <span class="input-group-text"><i class="bi bi-search"></i></span>
          <input type="text" name="search" class="form-control" value="@Model.Search"
                 placeholder="Community name or LGA…" />
        </div>
      </div>
      <div class="col-md-3">
        <label class="form-label mb-1">Status</label>
        <select name="status" class="form-select form-select-sm">
          <option value="">All Statuses</option>
          @foreach (var s in Enum.GetValues<BenueCommunityMapping.Models.SubmissionStatus>())
          {
            <option value="@s" selected="@(Model.StatusFilter == s)">@s</option>
          }
        </select>
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-bsbs-primary btn-sm">Filter</button>
        <a asp-page="MySubmissions" class="btn btn-outline-secondary btn-sm ms-1">Reset</a>
      </div>
    </form>
  </div>
</div>

<!-- TABLE -->
<div class="table-card">
  <div class="table-card-header">
    <i class="bi bi-list-ul text-bsbs-green"></i>
    <h5 class="ms-1">Submissions</h5>
    <span class="ms-auto text-muted small">@Model.List.TotalItems record(s)</span>
  </div>
  @if (!Model.List.Data.Any())
  {
    <div class="empty-state">
      <i class="bi bi-inbox"></i>
      <p>No submissions found.</p>
      <a asp-page="/Questionnaire/Create" class="btn btn-bsbs-primary btn-sm">Create First Entry</a>
    </div>
  }
  else
  {
    <div class="table-responsive">
      <table class="bsbs-table">
        <thead>
          <tr>
            <th>#</th><th>Community</th><th>LGA</th><th>Ward</th><th>Kindred</th>
            <th>Status</th><th>Created</th><th>Submitted</th><th>Actions</th>
          </tr>
        </thead>
        <tbody>
          @{ int i = ((Model.List.PageNumber - 1) * 20) + 1; }
          @foreach (var s in Model.List.Data)
          {
            <tr>
              <td class="text-muted">@(i++)</td>
              <td><strong>@s.CommunityName</strong></td>
              <td>@s.LGA</td>
              <td class="text-muted">@s.Ward</td>
              <td>–</td>
              <td><span class="status-badge status-@s.Status.ToString().ToLower()">@s.Status</span></td>
              <td class="text-muted small">@s.CreatedAt.ToString("dd MMM yyyy")</td>
              <td class="text-muted small">@(s.SubmittedAt?.ToString("dd MMM yyyy") ?? "–")</td>
              <td>
                <div class="d-flex gap-1">
                  <a asp-page="/Questionnaire/View" asp-route-id="@s.Id"
                     class="btn btn-sm btn-bsbs-outline" title="View">
                    <i class="bi bi-eye"></i>
                  </a>
                  @if (s.Status == BenueCommunityMapping.Models.SubmissionStatus.Draft || s.Status == BenueCommunityMapping.Models.SubmissionStatus.Rejected)
                  {
                    <a asp-page="/Questionnaire/Edit" asp-route-id="@s.Id"
                       class="btn btn-sm btn-bsbs-primary" title="Edit">
                      <i class="bi bi-pencil"></i>
                    </a>
                  }
                  @if (s.Status == BenueCommunityMapping.Models.SubmissionStatus.Draft)
                  {
                    <form method="post" asp-page="/Questionnaire/Delete" asp-route-id="@s.Id"
                          onsubmit="return confirm('Delete this draft?')">
                      <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                        <i class="bi bi-trash3"></i>
                      </button>
                    </form>
                  }
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>

    <div class="d-flex justify-content-end mt-3 mb-3">
      <cs-pager cs-paging-pagenumber="@Model.List.PageNumber"
                cs-paging-totalitems="@Model.List.TotalItems"
                cs-paging-pagesize="20"
                cs-paging-maxpageritems="10"
                cs-pagenumber-param="p"
                asp-page="MySubmissions"
                asp-route-search="@Model.Search"
                cs-pager-ul-class="pagination"
                asp-route-status="@Model.StatusFilter"
                cs-pager-li-current-class="page-item active"
                cs-pager-link-other-class="page-link"
                cs-pager-link-current-class="page-link"></cs-pager>
    </div>
  }
</div>

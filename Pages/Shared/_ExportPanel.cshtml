@*
    Export panel partial — include on Admin/Analytics and DataAnalysis pages.
    Pass the current filter values so export links preserve them.

    Usage: <partial name="_ExportPanel" model="new { LgaId = ..., WardId = ..., ... }" />
    Or use ViewData keys: ExportLgaId, ExportWardId, ExportKindredId, ExportCommunityId, ExportFrom, ExportTo
*@

@{
    var lgaId       = ViewData["ExportLgaId"]?.ToString();
    var wardId      = ViewData["ExportWardId"]?.ToString();
    var kindredId   = ViewData["ExportKindredId"]?.ToString();
    var communityId = ViewData["ExportCommunityId"]?.ToString();
    var fromDate    = ViewData["ExportFrom"]?.ToString();
    var toDate      = ViewData["ExportTo"]?.ToString();

    string BuildUrl(string section, string format)
    {
        var qs = $"/Shared/Export?section={section}&format={format}";
        if (!string.IsNullOrEmpty(lgaId))       qs += $"&lgaId={lgaId}";
        if (!string.IsNullOrEmpty(wardId))      qs += $"&wardId={wardId}";
        if (!string.IsNullOrEmpty(kindredId))   qs += $"&kindredId={kindredId}";
        if (!string.IsNullOrEmpty(communityId)) qs += $"&communityId={communityId}";
        if (!string.IsNullOrEmpty(fromDate))    qs += $"&from={fromDate}";
        if (!string.IsNullOrEmpty(toDate))      qs += $"&to={toDate}";
        return qs;
    }

    var sections = new (string Key, string Label)[]
    {
        ("all",          "All Sections"),
        ("demographics", "A – Demographics"),
        ("markets",      "B – Markets"),
        ("health",       "C – Health"),
        ("education",    "D – Education"),
        ("roads",        "E – Roads"),
        ("finance",      "F – Finance"),
        ("environment",  "G – Environment"),
        ("telecom",      "I – Telecom"),
        ("security",     "J – Security"),
        ("geo_lga",      "LGA Summary"),
        ("community",    "Community Metrics"),
    };
}

<div class="content-card mb-4" id="exportPanel">
  <div class="content-card-header d-flex align-items-center" style="background: linear-gradient(135deg, #1b5e20, #2e7d32); color: #fff; padding: 12px 20px; border-radius: 8px 8px 0 0;">
    <i class="bi bi-download fs-5 me-2"></i>
    <h5 class="mb-0">Export Data</h5>
  </div>
  <div class="content-card-body p-3">
    <p class="text-muted small mb-3">
      <i class="bi bi-info-circle me-1"></i>Select a section and format. Exports respect your current location and date filters.
    </p>

    <div class="row g-3">
      @foreach (var s in sections)
      {
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body p-3">
              <h6 class="card-title mb-2">
                <i class="bi bi-folder2-open text-success me-1"></i>@s.Label
              </h6>
              <div class="d-flex flex-wrap gap-1">
                <a href="@BuildUrl(s.Key, "excel")" class="btn btn-sm btn-outline-success" title="Excel">
                  <i class="bi bi-file-earmark-excel me-1"></i>Excel
                </a>
                <a href="@BuildUrl(s.Key, "csv")" class="btn btn-sm btn-outline-secondary" title="CSV">
                  <i class="bi bi-filetype-csv me-1"></i>CSV
                </a>
                <a href="@BuildUrl(s.Key, "pdf")" class="btn btn-sm btn-outline-danger" title="PDF">
                  <i class="bi bi-file-earmark-pdf me-1"></i>PDF
                </a>
                <a href="@BuildUrl(s.Key, "docx")" class="btn btn-sm btn-outline-primary" title="Word">
                  <i class="bi bi-file-earmark-word me-1"></i>Word
                </a>
              </div>
            </div>
          </div>
        </div>
      }
    </div>
  </div>
</div>

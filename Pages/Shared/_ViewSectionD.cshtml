@model BenueCommunityMapping.Models.QuestionnaireSubmission
<div class="accordion-item border-0 mb-2">
  <h2 class="accordion-header">
    <button class="accordion-button collapsed fw-semibold" type="button"
            data-bs-toggle="collapse" data-bs-target="#collapseD">
      <i class="bi bi-mortarboard me-2 text-bsbs-green"></i>Section D: Educational Institutions
    </button>
  </h2>
  <div id="collapseD" class="accordion-collapse collapse" data-bs-parent="#viewAccordion">
    <div class="accordion-body bg-white border border-top-0 rounded-bottom">
      <div class="row g-2 mb-3">
        <div class="col-md-4"><small class="text-muted d-block">Children Not in School</small><strong>@(Model.ChildrenNotInSchool?.ToString() ?? "–")</strong></div>
        <div class="col-md-4"><small class="text-muted d-block">Schools Hosting IDPs?</small><strong>@(Model.SchoolsCurrentlyHostingIDPs ? "Yes" : "No")</strong></div>
        <div class="col-12"><small class="text-muted">Key Challenges:</small> @(Model.EducationKeyChallenges ?? "–")</div>
        @if (!string.IsNullOrEmpty(Model.NearestInstitutionIfNone))
        {
          <div class="col-12"><small class="text-muted">Nearest Institution (none in community):</small> @Model.NearestInstitutionIfNone</div>
        }
      </div>
      @if (Model.EducationalInstitutions.Any())
      {
        <div class="table-responsive">
          <table class="bsbs-table">
            <thead><tr><th>Institution</th><th>Type</th><th>Owner</th><th>Distance</th><th>Infrastructure</th><th>Conflict Closure?</th></tr></thead>
            <tbody>
              @foreach (var inst in Model.EducationalInstitutions)
              {
                <tr>
                  <td>@(inst.Name ?? "–")</td><td>@(inst.Type?.ToString() ?? "–")</td>
                  <td>@(inst.Owner ?? "–")</td><td>@(inst.DistanceFromCentre?.ToString() ?? "–")</td>
                  <td>@(inst.InfrastructureCondition?.ToString() ?? "–")</td>
                  <td>@(inst.DestroyedOrClosedDueToConflict.HasValue ? (inst.DestroyedOrClosedDueToConflict.Value ? $"Yes ({inst.ConflictClosureYear})" : "No") : "–")</td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      }
      else { <p class="text-muted">No institutions recorded.</p> }
    </div>
  </div>
</div>

<div class="row g-3 mb-3">
  <div class="col-12"><label class="form-label">How do you resolve disputes in your community?</label>
    <textarea name="SectionJ.HowCommunityResolvesDisputes" class="form-control" rows="3">@Model.HowCommunityResolvesDisputes</textarea>
  </div>
</div>

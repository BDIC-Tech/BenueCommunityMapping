@page
@model BenueCommunityMapping.Pages.ErrorModel
@{ Layout = "_Layout"; ViewData["Title"] = "Error"; }

<div class="page-hero mt-3" style="border-left-color:var(--bsbs-red)">
  <div class="hero-icon" style="background:rgba(192,57,43,.15);color:var(--bsbs-red)">
    <i class="bi bi-exclamation-triangle-fill"></i>
  </div>
  <div>
    <h1>Something went wrong</h1>
    <p>An unexpected error occurred. Please try again or contact support.</p>
  </div>
</div>

@if (Model.ShowRequestId)
{
  <div class="info-note">
    <strong>Request ID:</strong> <code>@Model.RequestId</code>
  </div>
}

<a asp-page="/Index" class="btn btn-bsbs-primary mt-2">
  <i class="bi bi-house me-1"></i>Return to Dashboard
</a>
